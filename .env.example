# Copy to .env and fill in real values -- .env is gitignored, never commit it.

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=changeme

DJANGO_DEBUG=false

# Comma-separated. Must include your domain (the one nginx terminates TLS for).
DJANGO_ALLOWED_HOSTS=yourdomain.com

# Comma-separated, scheme included. Needed for the CSRF Origin check on POSTs.
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Persisted outside the container via the docker-compose volume mount.
DATA_DIR=/data
